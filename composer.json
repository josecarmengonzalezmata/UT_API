{
  "name": "utslrc/api",
  "type": "project",
  "description": "Plain PHP API backend for the UTSLRC docente/admin system",
  "require": {
    "php": "^8.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "scripts": {
    "test": [
      "php -l public/index.php"
    ]
  },
  "config": {
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
